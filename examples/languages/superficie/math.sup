defn quadratic(a, b, c, x):
  a * x * x + b * x + c
end

defn abs(x):
  if x < 0:
    0 - x
  else:
    x
  end
end

defn factorial(n):
  loop i := n, acc := 1:
    if i <= 1:
      acc
    else:
      recur(i - 1, acc * i)
    end
  end
end

println(quadratic(1, 2, 1, 3))
println(abs(-42))
println(factorial(10))
